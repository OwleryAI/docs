{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "palm",
  "name": "How to Use Owlery",
  "description": "Step-by-step guides for every product—platform setup, analytics, and integrations in one place.",
  "colors": {
    "primary": "#166E3F",
    "light": "#26BD6C",
    "dark": "#166E3F"
  },
  "favicon": "/favicon.ico",
  "icons": {
    "library": "fontawesome"
  },
  "styling": {
    "eyebrows": "breadcrumbs"
  },
  "contextual": {
    "options": [
      "copy",
      "assistant",
      "chatgpt",
      "claude",
      "download-pdf"
    ],
    "display": "toc"
  },
  "navigation": {
    "directory": "card",
    "pages": [
      {
        "group": "Getting Started",
        "pages": [
          "getting-started-in-4-steps",
          "welcome"
        ]
      },
      {
        "group": "Platform",
        "icon": "layer-group",
        "pages": [
          "orders",
          "loads",
          "invoices"
        ]
      },
      "item-master",
      "contract-rates",
      "shipper-settings",
      "integrations",
      {
        "group": "Analytics",
        "icon": "chart-line",
        "pages": [
          "coming-soon"
        ]
      },
      "need-help"
    ]
  },
  "logo": {
    "light": "/images/Owlery-Logo-RGB.svg",
    "dark": "/images/Owlery-Logo-Reversed.svg"
  },
  "navbar": {
    "links": [],
    "primary": {
      "type": "button",
      "label": "Log in to Owlery",
      "href": "https://owlery.ai/dashboard"
    }
  },
  "footer": {
    "socials": {
      "linkedin": "https://linkedin.com/in/owlery"
    }
  },
  "fonts": {
    "family": "Open Sans"
  }
}
