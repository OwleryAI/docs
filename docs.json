{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "palm",
  "name": "How to Use Owlery",
  "description": "Owlery is the AI-powered TMS and Logistics Platform built for modern logistics. We know that No One Ships Alone - this guide has everything you need to get set up and moving freight, no matter which side of the shipment you're on.",
  "colors": {
    "primary": "#166E3F",
    "light": "#26BD6C",
    "dark": "#166E3F"
  },
  "favicon": {
    "light": "/images/697b1f7cf8fe0d76b21e0e58_FavIcon(32x32).svg",
    "dark": "/images/697b1f7cf8fe0d76b21e0e58_FavIcon(32x32).svg"
  },
  "icons": {
    "library": "fontawesome"
  },
  "styling": {
    "eyebrows": "breadcrumbs"
  },
  "contextual": {
    "options": [
      "assistant"
    ],
    "display": "toc"
  },
  "navigation": {
    "directory": "card",
    "tabs": [
      {
        "tab": "Getting Started",
        "icon": "flag-checkered",
        "pages": [
          "welcome",
          "signing-in",
          "switch-to-dark-mode"
        ]
      },
      {
        "tab": "Shippers",
        "pages": [
          {
            "group": "Getting Started",
            "icon": "rocket",
            "pages": [
              "shippers/welcome",
              "shippers/getting-started-in-4-steps"
            ]
          },
          "shippers/integrations",
          {
            "group": "Platform",
            "icon": "layer-group",
            "pages": [
              "shippers/orders",
              "shippers/quotes",
              "shippers/review-responses-and-tender",
              "shippers/two-step-tendering",
              "shippers/loads",
              "shippers/invoices"
            ]
          },
          "shippers/item-master",
          {
            "group": "Contract Rates",
            "icon": "handshake",
            "pages": [
              "shippers/contract-rates-overview",
              "shippers/contract-rates-page",
              "shippers/adding-contract-rates",
              "shippers/fuel-surcharges"
            ]
          },
          {
            "group": "Shipper Settings",
            "icon": "gear",
            "pages": [
              "shippers/shipper-settings",
              "shippers/payment-due-date-rules"
            ]
          },
          {
            "group": "Analytics",
            "icon": "chart-line",
            "pages": [
              "shippers/coming-soon"
            ]
          },
          "shippers/need-help"
        ],
        "icon": "boxes-stacked"
      },
      {
        "tab": "Carriers",
        "icon": "truck",
        "pages": [
          "carriers/overview",
          {
            "group": "Quotes & Tenders",
            "icon": "file-signature",
            "pages": [
              "carriers/submit-a-quote",
              "carriers/accept-a-tender",
              "carriers/edit-a-load-number"
            ]
          },
          {
            "group": "During Transit",
            "icon": "route",
            "pages": [
              "carriers/update-shipment-tracking",
              "carriers/upload-proof-of-delivery"
            ]
          },
          {
            "group": "Invoicing",
            "icon": "file-invoice-dollar",
            "pages": [
              "carriers/submit-an-invoice",
              "untitled-page",
              "carriers/track-and-fix-invoices"
            ]
          },
          "carriers/invite-teammates"
        ]
      },
      {
        "tab": "Facilities",
        "icon": "warehouse",
        "pages": [
          "facilities/facility-profile",
          "facilities/dock-appointment-settings",
          "facilities/driver-check-in"
        ]
      },
      {
        "tab": "Dock Scheduling",
        "icon": "calendar-clock",
        "pages": [
          "dock-scheduling/coming-soon"
        ]
      }
    ]
  },
  "logo": {
    "light": "/images/Owlery-Logo-RGB.svg",
    "dark": "/images/Owlery-Logo-Reversed.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Email Support",
        "href": "mailto:support@owlery.ai"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Log in to Owlery",
      "href": "https://owlery.ai/dashboard"
    }
  },
  "fonts": {
    "family": "Open Sans"
  },
  "redirects": [
    {
      "source": "/carriers/create-an-invoice",
      "destination": "/carriers/submit-an-invoice"
    },
    {
      "source": "/shippers/contract-rates",
      "destination": "/shippers/contract-rates-overview"
    },
    {
      "source": "/shippers",
      "destination": "/shippers/welcome"
    },
    {
      "source": "/carriers",
      "destination": "/carriers/overview"
    },
    {
      "source": "/facilities",
      "destination": "/facilities/facility-profile"
    },
    {
      "source": "/dock-scheduling",
      "destination": "/dock-scheduling/coming-soon"
    }
  ],
  "errors": {
    "404": {
      "redirect": false,
      "title": "Uh oh. This page doesn't exist.",
      "description": "Don't worry, we can get you back on track.\n\nUse the **search box** or **AI Assistant** at the top of the page to find what you need or head back to the [Help Center's homepage](https://help.owlery.ai).\n\n<iframe src=\"https://www.youtube.com/embed/insM7oUYNOE\" frameBorder=\"0\" allow=\"accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture\" allowFullScreen style={{width: '100%', maxWidth: '560px', aspectRatio: '16/9'}}></iframe>"
    }
  }
}
