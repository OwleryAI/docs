{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "palm",
  "name": "How to Use Owlery",
  "description": "Step-by-step guides for every product—platform setup, analytics, and integrations in one place.",
  "colors": {
    "primary": "#166E3F",
    "light": "#26BD6C",
    "dark": "#166E3F"
  },
  "favicon": "/favicon.ico",
  "icons": {
    "library": "fontawesome"
  },
  "styling": {
    "eyebrows": "breadcrumbs"
  },
  "contextual": {
    "options": [
      "assistant",
      "claude",
      "chatgpt"
    ],
    "display": "toc"
  },
  "navigation": {
    "directory": "card",
    "tabs": [
      {
        "tab": "Owlery Product Guide",
        "pages": [
          "welcome-1"
        ]
      },
      {
        "tab": "Shippers",
        "pages": [
          {
            "group": "Getting Started",
            "pages": [
              "shippers/welcome",
              "shippers/getting-started-in-4-steps"
            ]
          },
          {
            "group": "Platform",
            "icon": "layer-group",
            "pages": [
              "shippers/orders",
              "shippers/loads",
              "shippers/invoices"
            ]
          },
          "shippers/item-master",
          "shippers/contract-rates",
          "shippers/shipper-settings",
          "integrations",
          {
            "group": "Analytics",
            "icon": "chart-line",
            "pages": [
              "coming-soon"
            ]
          },
          "need-help"
        ],
        "icon": "star"
      },
      {
        "tab": "Carriers",
        "icon": "truck",
        "pages": [
          "carriers/overview",
          "carriers/portal/submit-a-quote",
          "carriers/portal/accept-a-tender",
          "carriers/portal/update-shipment-tracking",
          "carriers/portal/upload-proof-of-delivery",
          "carriers/portal/create-an-invoice",
          "carriers/portal/invite-teammates"
        ]
      },
      {
        "tab": "Facilities",
        "icon": "warehouse"
      },
      {
        "tab": "Appointment Booking",
        "icon": "calendar-alt"
      }
    ]
  },
  "logo": {
    "light": "/images/Owlery-Logo-RGB.svg",
    "dark": "/images/Owlery-Logo-Reversed.svg"
  },
  "navbar": {
    "links": [],
    "primary": {
      "type": "button",
      "label": "Log in to Owlery",
      "href": "https://owlery.ai/dashboard"
    }
  },
  "footer": {
    "socials": {
      "linkedin": "https://linkedin.com/in/owlery"
    }
  },
  "fonts": {
    "family": "Open Sans"
  }
}
